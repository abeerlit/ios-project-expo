API_URL=https://api.voxo.co
GOOGLE_CLIENT_ID=
AZURE_CLIENT_ID=
SEND_BIRD_APP_ID=
SEND_BIRD_APP_TOKEN=
GIPHY_IOS_KEY=
GIPHY_ANDROID_KEY=
SENTRY_DSN=
SENTRY_DNS=
MESSAGING_UPLOAD_API_URL=
ENABLE_GOOGLE_SSO=true
ENABLE_MICROSOFT_SSO=true

# Expo runtime flags (phase gates) — read by app.config.ts at prebuild / ios:setup
# 1 = enable native telephony plugins (CallKit, PushKit, VoxoNative)
EXPO_PUBLIC_NATIVE_TELEPHONY=1
EXPO_PUBLIC_NATIVE_NOTIFICATIONS=1
# 1 = real Sendbird provider (notifee stubbed until EXPO_PUBLIC_NATIVE_NOTIFICATIONS=1)
EXPO_PUBLIC_CHAT_NATIVE=1
EXPO_PUBLIC_MEETINGS_NATIVE=1
# 0 = JS stubs for unlinked natives; rebuild dev client after Podfile setup_permissions for permission dialogs
EXPO_PUBLIC_NATIVE_FULL=0

# White label (phase 9)
IOS_BUNDLE_ID=co.voxo.voxo-ios
APP_GROUP=group.co.voxo.voxo-ios
DISPLAY_NAME=VOXO Connect
# Optional: override org name in permission copy (default: strips " Connect" from DISPLAY_NAME)
# ORGANIZATION_NAME=VOXO
# LEGAL_TERMS_URL=https://example.com/terms
# LEGAL_PRIVACY_URL=https://example.com/privacy
APP_ICON=./branding/voxo/icon.png
SPLASH_IMAGE=./branding/voxo/splash.png
# SPLASH_BACKGROUND_COLOR=#ffffff
GOOGLE_SERVICES_PLIST=./native-resources/GoogleService-Info.plist
APS_ENVIRONMENT=development
