{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": false,
        "resourceClass": "m-medium",
        "image": "macos-sequoia-15.6-xcode-26.2"
      },
      "env": {
        "APS_ENVIRONMENT": "development",
        "EXPO_PUBLIC_NATIVE_TELEPHONY": "0"
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "resourceClass": "m-medium",
        "image": "macos-sequoia-15.6-xcode-26.2"
      },
      "env": {
        "EXPO_PUBLIC_NATIVE_TELEPHONY": "1",
        "EXPO_PUBLIC_NATIVE_NOTIFICATIONS": "1"
      }
    },
    "production": {
      "ios": {
        "resourceClass": "m-medium",
        "autoIncrement": true,
        "image": "macos-sequoia-15.6-xcode-26.2"
      },
      "env": {
        "APP_VERSION": "2.1.3",
        "IOS_BUILD_NUMBER": "11",
        "EXPO_PUBLIC_NATIVE_TELEPHONY": "1",
        "EXPO_PUBLIC_NATIVE_NOTIFICATIONS": "1",
        "EXPO_PUBLIC_MEETINGS_NATIVE": "1",
        "APP_ICON": "./branding/voxo/icon.png",
        "SPLASH_IMAGE": "./branding/voxo/splash.png",
        "IOS_BUNDLE_ID": "co.voxo.voxo-ios",
        "APP_GROUP": "group.co.voxo.voxo-ios",
        "DISPLAY_NAME": "VOXO Connect",
        "EXPO_PUBLIC_CHAT_NATIVE": "1",
        "GOOGLE_SERVICES_PLIST": "./native-resources/tenants/voxo/GoogleService-Info.plist",
        "ORGANIZATION_NAME": "VOXO"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "abeerahmad204@gmail.com",
        "ascAppId": "1633460300",
        "appleTeamId": "FLD7A54T23"
      }
    },
    "tenant-a-production": {
      "ios": {
        "appleId": "${APPLE_ID}",
        "ascAppId": "${ASC_APP_ID}",
        "appleTeamId": "${APPLE_TEAM_ID}"
      },
      "extends": "production"
    },
    "tenant-b-production": {
      "ios": {
        "appleId": "${APPLE_ID}",
        "ascAppId": "${ASC_APP_ID}",
        "appleTeamId": "${APPLE_TEAM_ID}"
      },
      "extends": "production"
    }
  }
}
