{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": false,
    "baseUrl": ".",
    "paths": {
      "@api/*": ["src/api/*"],
      "@assets/*": ["src/assets/*"],
      "@components/*": ["src/components/*"],
      "@composable/*": ["src/hooks/*"],
      "@core/*": ["src/core/*"],
      "@helpers/*": ["src/helpers/*"],
      "@layouts/*": ["src/layouts/*"],
      "@navigations/*": ["src/navigations/*"],
      "@router/*": ["src/router/*"],
      "@store/*": ["src/store/*"],
      "@types/*": ["src/types/*"],
      "@views/*": ["src/views/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", "expo-shell/**/*.ts", "expo-shell/**/*.tsx"],
  "exclude": ["node_modules", "ios", "android"]
}
