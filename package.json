{
  "name": "voxo-connect-ios-expo",
  "version": "0.0.1",
  "private": true,
  "main": "index.js",
  "scripts": {
    "postinstall": "patch-package && node scripts/ensure-ios-codegen.js && node scripts/sync-ui-branding.js",
    "ui-branding:sync": "node scripts/sync-ui-branding.js",
    "vendor:sync-bare": "node scripts/vendor-sync-from-bare.js",
    "branding:sync": "node scripts/sync-branding-from-bare.js",
    "kill-metro": "lsof -ti :8081 | xargs kill -9 2>/dev/null; lsof -ti :8083 | xargs kill -9 2>/dev/null; echo 'Metro ports cleared'",
    "start": "npm run kill-metro && REACT_NATIVE_PACKAGER_HOSTNAME=$(ipconfig getifaddr en0 || ipconfig getifaddr en1) expo start --dev-client --host lan --port 8081",
    "start:device": "npm run kill-metro && REACT_NATIVE_PACKAGER_HOSTNAME=$(ipconfig getifaddr en0 || ipconfig getifaddr en1) expo start --dev-client --host lan --port 8081",
    "start:device:fresh": "npm run kill-metro && REACT_NATIVE_PACKAGER_HOSTNAME=$(ipconfig getifaddr en0 || ipconfig getifaddr en1) expo start --dev-client --host lan --port 8081 --clear",
    "ios": "expo run:ios",
    "ios:device": "REACT_NATIVE_PACKAGER_HOSTNAME=$(ipconfig getifaddr en0 || ipconfig getifaddr en1) expo run:ios --device 00008110-0012319C14EA201E",
    "ios:setup": "node scripts/ios-setup.js",
    "ios:setup:clean": "node scripts/ios-setup.js --prebuild-clean",
    "ios:setup:verify": "node scripts/ios-setup.js --verify",
    "ios:codegen": "node scripts/ensure-ios-codegen.js",
    "ios:pod-install": "node scripts/ios-setup.js",
    "ios:fix-screen-capture": "node scripts/fix-screen-capture-extension-ios.js && node scripts/repair-ios-embedded-extensions.js",
    "ios:fix-nse": "node scripts/fix-voxo-notification-extension-ios.js && node scripts/repair-ios-embedded-extensions.js",
    "ios:telephony": "node scripts/sync-voxo-telephony-ios.js && npm run ios:pod-install",
    "ios:meetings": "node scripts/setup-screen-capture-extension-ios.js && npm run ios:pod-install",
    "prebuild": "expo prebuild --platform ios",
    "prebuild:clean": "node scripts/ios-setup.js --prebuild-clean",
    "lint": "eslint . --max-warnings 0",
    "check:types": "tsc --noEmit",
    "editor:build": "vite --config ./src/features/chat/editor/vite.config.ts build",
    "editor:post-build": "node ./node_modules/@10play/tentap-editor/scripts/buildEditor.js ./src/features/chat/editor/build/index.html",
    "eas:development": "eas build --profile development --platform ios",
    "eas:preview": "eas build --profile preview --platform ios",
    "eas:production": "eas build --profile production --platform ios",
    "android": "expo run:android"
  },
  "dependencies": {
    "@10play/tentap-editor": "^0.7.2",
