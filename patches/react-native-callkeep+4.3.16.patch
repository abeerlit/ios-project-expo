+/// Report call ended without CXEndCallAction (same semantics as Code=4 fallback).
+- (void)voxoReportEndedDirectly:(NSUUID *)uuid
+{
+    CXProvider *provider = sharedProvider != nil ? sharedProvider : self.callKeepProvider;
+    if (provider == nil) {
+        NSLog(@"[VOXO_CK] voxoReportEndedDirectly: no provider uuid=%@", uuid.UUIDString);
+        return;
+    }
+    __weak typeof(self) weakSelf = self;
+    dispatch_async(dispatch_get_main_queue(), ^{
+        [provider reportCallWithUUID:uuid endedAtDate:[NSDate date] reason:CXCallEndedReasonRemoteEnded];
+        NSLog(@"[VOXO_CK] reportEndedDirectly done uuid=%@", uuid.UUIDString);
+
+        RNCallKeep *innerSelf = weakSelf;
+        if (innerSelf != nil) {
+            [innerSelf voxoScheduleRecycleAfterCallEnded];
+        }
+    });
+}
