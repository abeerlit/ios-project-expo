+static BOOL voxoRKTitleLooksDialable(NSString *title)
+{
+    NSString *t = voxoRKTrim(title);
+    if (t.length < 3 || t.length > 40) {
+        return NO;
+    }
+    NSCharacterSet *allowed = [NSCharacterSet characterSetWithCharactersInString:@"+0123456789 *#()-."];
+    NSCharacterSet *inverted = [allowed invertedSet];
+    return [t rangeOfCharacterFromSet:inverted].location == NSNotFound;
+}
