+- (void)voxoStoreRecentsIntentPayloadForUuid:(NSUUID *)uuid
+                                 displayName:(NSString *)dn
+                                  dialHandle:(NSString *)dial
+{
+    if (uuid == nil) {
+        return;
+    }
+    NSString *k = uuid.UUIDString.uppercaseString;
+    @synchronized (self) {
+        if (_voxoRecentsIntentPayloadByUuid == nil) {
+            _voxoRecentsIntentPayloadByUuid = [NSMutableDictionary dictionary];
+        }
+        _voxoRecentsIntentPayloadByUuid[k] = @{
+            @"displayName": dn ?: @"",
+            @"dialHandle": dial ?: @""
+        };
+    }
+    NSLog(@"[VOXO_RECENTS_CK] intentPayload STORED uuid=%@ nameLen=%lu dialLen=%lu",
+          k,
+          (unsigned long)voxoRKTrim(dn).length,
+          (unsigned long)voxoRKTrim(dial).length);
+}
+
+- (NSDictionary *)voxoTakeRecentsIntentPayloadForUuid:(NSUUID *)uuid
+{
+    if (uuid == nil) {
+        return nil;
+    }
+    NSString *k = uuid.UUIDString.uppercaseString;
+    NSDictionary *out = nil;
+    @synchronized (self) {
+        NSDictionary *o = _voxoRecentsIntentPayloadByUuid[k];
+        if (o != nil) {
+            [_voxoRecentsIntentPayloadByUuid removeObjectForKey:k];
+            NSLog(@"[VOXO_RECENTS_CK] intentPayload TAKE uuid=%@ nameLen=%lu dialLen=%lu",
+                  k,
+                  (unsigned long)voxoRKTrim([o objectForKey:@"displayName"]).length,
+                  (unsigned long)voxoRKTrim([o objectForKey:@"dialHandle"]).length);
+        } else {
+            NSLog(@"[VOXO_RECENTS_CK] intentPayload TAKE uuid=%@ none (no stashed INPerson payload)", k);
+        }
+        out = o;
+    }
+    return out;
+}
