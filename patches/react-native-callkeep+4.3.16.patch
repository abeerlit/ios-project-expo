+/// Recreate CXProvider after calls end so subsequent starts receive performStartCallAction reliably.
+- (void)voxoRecycleCallKitProviderNow
+{
+    NSDictionary *settings = [RNCallKeep getSettings];
+    if (settings == nil) {
+        NSLog(@"[VOXO_CK] voxoRecycleCallKitProviderNow: no RNCallKeepSettings — abort");
+        return;
+    }
+    if (sharedProvider != nil) {
+        [sharedProvider invalidate];
+        sharedProvider = nil;
+    }
+    sharedProvider = [[CXProvider alloc] initWithConfiguration:[RNCallKeep getProviderConfiguration:settings]];
+    RNCallKeep *singleton = [RNCallKeep allocWithZone:nil];
+    singleton.callKeepProvider = sharedProvider;
+    [sharedProvider setDelegate:singleton queue:nil];
+    NSLog(@"[VOXO_CK] voxoRecycleCallKitProviderNow: rebuilt CXProvider + delegate");
+}
+
+- (void)voxoPerformRecycleWithRetries:(NSUInteger)retriesLeft
+{
+    CXCallObserver *obs = [[CXCallObserver alloc] init];
+    if (obs.calls.count == 0) {
+        [self voxoRecycleCallKitProviderNow];
+        self->_voxoRecycleScheduled = NO;
+        return;
+    }
+    if (retriesLeft == 0) {
+        NSLog(@"[VOXO_CK] voxoRecycle: CXCallObserver still has %lu call(s) — skipping recycle",
+              (unsigned long)obs.calls.count);
+        self->_voxoRecycleScheduled = NO;
+        return;
+    }
+    dispatch_after(dispatch_time(DISPATCH_TIME_NOW, (int64_t)(0.35 * NSEC_PER_SEC)),
+                   dispatch_get_main_queue(), ^{
+        [self voxoPerformRecycleWithRetries:retriesLeft - 1];
+    });
+}
+
+/// Schedule provider recycle once CallKit observer shows no active calls.
+- (void)voxoScheduleRecycleAfterCallEnded
+{
+    if (_voxoRecycleScheduled) {
+        NSLog(@"[VOXO_CK] voxoScheduleRecycleAfterCallEnded: already scheduled — skip");
+        return;
+    }
+    _voxoRecycleScheduled = YES;
+    // Defer recycle so Phone → Recents can finish associating the ended call with this app
+    // before CXProvider is torn down (helps tap-to-return from Recents).
+    dispatch_after(dispatch_time(DISPATCH_TIME_NOW, (int64_t)(2.5 * NSEC_PER_SEC)),
+                   dispatch_get_main_queue(), ^{
+        [self voxoPerformRecycleWithRetries:6];
+    });
+}
