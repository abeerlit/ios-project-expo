+        [self voxoReportEndedDirectly:uuid];
+        return;
+    }
+
+    if (matchingCall.hasEnded) {
+        NSLog(@"[VOXO_CK] endCall: observer shows hasEnded — skip CXEndCallAction uuid=%@", uuid.UUIDString);
+        return;
+    }
+
