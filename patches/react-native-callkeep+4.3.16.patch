+/// Final CXCallUpdate merged into the call record Phone.app archives (apply immediately before ended).
+static void VoxoApplyRecentsEndSnapshotIfNeeded(CXProvider *provider, NSUUID *uuid, NSString *displayName, NSString *handleUri)
+{
+    if (provider == nil || uuid == nil) {
+        return;
+    }
+    NSString *dn = voxoRKTrim(displayName);
+    NSString *uri = voxoRKTrim(handleUri);
+    if (dn.length == 0 && uri.length == 0) {
+        NSLog(@"[VOXO_RECENTS_CK] pre-end snapshot skip (empty) uuid=%@", uuid.UUIDString);
+        return;
+    }
+    CXCallUpdate *callUpdate = [[CXCallUpdate alloc] init];
+    if (dn.length > 0) {
+        callUpdate.localizedCallerName = dn;
+    }
+    CXHandleType ht = VoxoCallKeepHandleTypeForUpdateDisplayUri(uri);
+    if (ht == CXHandleTypePhoneNumber) {
+        callUpdate.remoteHandle = [[CXHandle alloc] initWithType:CXHandleTypePhoneNumber value:uri];
+    }
+    if (callUpdate.localizedCallerName.length > 0 || callUpdate.remoteHandle != nil) {
+        [provider reportCallWithUUID:uuid updated:callUpdate];
+        NSLog(@"[VOXO_RECENTS_CK] pre-end snapshot uuid=%@ nameApplied=%d phoneApplied=%d",
+              uuid.UUIDString,
+              (int)(callUpdate.localizedCallerName.length > 0),
+              (int)(callUpdate.remoteHandle != nil));
+    } else {
+        NSLog(@"[VOXO_RECENTS_CK] pre-end snapshot skip (no applicable fields) uuid=%@", uuid.UUIDString);
+    }
+}
