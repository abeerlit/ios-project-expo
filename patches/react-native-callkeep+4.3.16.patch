+/** Strict E.164, or short numeric PBX extension (3–8 digits) for Phone → Recents "Phone" row. */
+static CXHandleType VoxoCallKeepHandleTypeForUpdateDisplayUri(NSString *uri)
+{
+    NSString *t = [(uri ?: @"") stringByTrimmingCharactersInSet:[NSCharacterSet whitespaceAndNewlineCharacterSet]];
+    if (t.length == 0) {
+        return CXHandleTypeGeneric;
+    }
+    NSString *lower = t.lowercaseString;
+    if ([lower hasPrefix:@"sip:"] || [lower containsString:@"@"]) {
+        return CXHandleTypeGeneric;
+    }
+    // Strict E.164: leading + then digits only (ITU-T max 15 digits after +).
+    if ([t hasPrefix:@"+"] && t.length >= 9 && t.length <= 16) {
+        BOOL e164Ok = YES;
+        for (NSUInteger i = 1; i < t.length; i++) {
+            unichar c = [t characterAtIndex:i];
+            if (c < '0' || c > '9') {
+                e164Ok = NO;
+                break;
+            }
+        }
+        if (e164Ok) {
+            return CXHandleTypePhoneNumber;
+        }
+    }
+    // PBX extension (e.g. 1015): digits only, short — fills Phone field like PSTN rows; redial goes through app.
+    if (t.length >= 3 && t.length <= 8) {
+        BOOL allDigit = YES;
+        for (NSUInteger i = 0; i < t.length; i++) {
+            unichar c = [t characterAtIndex:i];
+            if (c < '0' || c > '9') {
+                allDigit = NO;
+                break;
+            }
+        }
+        if (allDigit) {
+            return CXHandleTypePhoneNumber;
+        }
+    }
+    return CXHandleTypeGeneric;
+}
