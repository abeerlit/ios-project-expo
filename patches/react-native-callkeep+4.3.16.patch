+- (void)voxoApplyStoredRecentsSnapshotBeforeEndForUuid:(NSUUID *)uuid
+{
+    NSString *key = uuid.UUIDString.uppercaseString;
+    NSDictionary *snap = nil;
+    @synchronized (self) {
+        snap = _voxoRecentsEndSnapshotByUuid[key];
+        if (snap != nil) {
+            [_voxoRecentsEndSnapshotByUuid removeObjectForKey:key];
+        }
+    }
+    if (snap == nil) {
+        return;
+    }
+    NSString *dn = voxoRKTrim([snap objectForKey:@"displayName"]);
+    NSString *handle = voxoRKTrim([snap objectForKey:@"handle"]);
+    void (^apply)(void) = ^{
