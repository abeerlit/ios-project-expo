+static NSString *voxoRKTrim(NSString *s)
+{
+    return s ? [s stringByTrimmingCharactersInSet:[NSCharacterSet whitespaceAndNewlineCharacterSet]] : @"";
+}
+
+/// Phone → Recents sometimes leaves `personHandle.value` empty but fills `phoneNumbers`.
+/// Use KVC for `phoneNumbers` / `phoneNumber` so this compiles when Intents headers omit typed properties.
+static NSString *VoxoRKDialableHandleFromINPerson(INPerson *person)
+{
+    if (person == nil) {
+        return nil;
+    }
+    INPersonHandle *ph = person.personHandle;
+    NSString *fromHandle = voxoRKTrim(ph.value);
+    if (fromHandle.length > 0) {
+        return fromHandle;
+    }
+    @try {
+        id phones = [person valueForKey:@"phoneNumbers"];
+        if ([phones isKindOfClass:[NSArray class]]) {
+            for (id pn in (NSArray *)phones) {
+                if (pn == nil) {
+                    continue;
+                }
+                id rawNum = [pn valueForKey:@"phoneNumber"];
+                NSString *num = voxoRKTrim([rawNum isKindOfClass:[NSString class]] ? rawNum : [rawNum description]);
+                if (num.length > 0) {
+                    return num;
+                }
+            }
+        }
+    } @catch (__unused NSException *e) {
+    }
+    return nil;
+}
+
+/// Best-effort display name from Recents / Siri `INPerson` (for CallKit `localizedCallerName` + JS `name`).
+static NSString *VoxoRKDisplayNameFromINPerson(INPerson *person)
+{
+    if (person == nil) {
+        return @"";
+    }
+    NSString *dn = voxoRKTrim(person.displayName);
+    if (dn.length > 0) {
+        return dn;
+    }
+    @try {
+        NSString *nick = voxoRKTrim([person valueForKey:@"nickname"]);
+        if (nick.length > 0) {
+            return nick;
+        }
+    } @catch (__unused NSException *e) {
+    }
+    if (@available(iOS 12.0, *)) {
+        NSPersonNameComponents *nc = person.nameComponents;
+        if (nc != nil) {
+            NSPersonNameComponentsFormatter *fmt = [[NSPersonNameComponentsFormatter alloc] init];
+            fmt.style = NSPersonNameComponentsFormatterStyleDefault;
+            NSString *formatted = voxoRKTrim([fmt stringFromPersonNameComponents:nc]);
+            if (formatted.length > 0) {
+                return formatted;
+            }
+        }
+    }
+    @try {
+        NSString *gn = voxoRKTrim([person valueForKey:@"givenName"]);
+        NSString *fn = voxoRKTrim([person valueForKey:@"familyName"]);
+        NSMutableArray *parts = [NSMutableArray array];
+        if (gn.length > 0) {
+            [parts addObject:gn];
+        }
+        if (fn.length > 0) {
+            [parts addObject:fn];
+        }
+        if (parts.count > 0) {
+            return [parts componentsJoinedByString:@" "];
+        }
+    } @catch (__unused NSException *e) {
+    }
+    return @"";
+}
