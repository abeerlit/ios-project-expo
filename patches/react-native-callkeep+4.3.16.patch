+RCT_REMAP_METHOD(popPendingRecentsIntent,
+                 popPendingRecentsIntentWithResolver:(RCTPromiseResolveBlock)resolve
+                 rejecter:(RCTPromiseRejectBlock)reject)
+{
+    NSUserDefaults *d = [NSUserDefaults standardUserDefaults];
+    NSString *handle = [d stringForKey:kVoxoPendingRecentsHandleKey];
+    NSString *uuid = [d stringForKey:kVoxoPendingRecentsUUIDKey];
+    NSTimeInterval ts = [d doubleForKey:kVoxoPendingRecentsTsKey];
+    NSString *pendingName = voxoRKTrim([d stringForKey:kVoxoPendingRecentsDisplayNameKey]);
+    [d removeObjectForKey:kVoxoPendingRecentsHandleKey];
+    [d removeObjectForKey:kVoxoPendingRecentsUUIDKey];
+    [d removeObjectForKey:kVoxoPendingRecentsTsKey];
+    [d removeObjectForKey:kVoxoPendingRecentsDisplayNameKey];
+    [d synchronize];
+
+    NSTimeInterval now = [[NSDate date] timeIntervalSince1970];
+    const NSTimeInterval kMaxAgeSeconds = 180.0;
+    if (handle.length > 0 && uuid.length > 0 && (now - ts) <= kMaxAgeSeconds) {
+        NSLog(@"[VOXO_CK] popPendingRecentsIntent → JS handle=%@ uuid=%@ nameLen=%lu age=%.2fs",
+              handle,
+              uuid,
+              (unsigned long)pendingName.length,
+              now - ts);
+        NSMutableDictionary *out = [@{
+            @"handle": handle,
+            @"callUUID": uuid
+        } mutableCopy];
+        if (pendingName.length > 0) {
+            out[@"name"] = pendingName;
+        }
+        resolve(out);
+    } else {
+        NSLog(@"[VOXO_CK] popPendingRecentsIntent → empty/stale (hLen=%lu uLen=%lu age=%.2fs)",
+              (unsigned long)handle.length,
+              (unsigned long)uuid.length,
+              (handle.length > 0 && uuid.length > 0) ? (now - ts) : -1.0);
+        resolve([NSNull null]);
+    }
+}
