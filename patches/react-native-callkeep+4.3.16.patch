+/// Scan every contact on audio / video / generic start-call intents.
+static NSString *VoxoRKDialableHandleFromStartCallIntent(INIntent *intent)
+{
+    if (intent == nil) {
+        return nil;
+    }
+    if ([intent isKindOfClass:[INStartAudioCallIntent class]]) {
+        for (INPerson *p in ((INStartAudioCallIntent *)intent).contacts) {
+            NSString *h = VoxoRKDialableHandleFromINPerson(p);
+            if (h.length > 0) {
+                return h;
+            }
+        }
+    } else if ([intent isKindOfClass:[INStartVideoCallIntent class]]) {
+        for (INPerson *p in ((INStartVideoCallIntent *)intent).contacts) {
+            NSString *h = VoxoRKDialableHandleFromINPerson(p);
+            if (h.length > 0) {
+                return h;
+            }
+        }
+    }
+    if ([intent isKindOfClass:[INStartCallIntent class]]) {
+        for (INPerson *p in ((INStartCallIntent *)intent).contacts) {
+            NSString *h = VoxoRKDialableHandleFromINPerson(p);
+            if (h.length > 0) {
+                return h;
+            }
+        }
+    }
+    return nil;
+}
